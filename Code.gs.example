// ==========================================
// Copy to Google Apps Script (Code.gs) → Deploy New version → Anyone
// Script Properties (optional overrides):
//   APP_USER, APP_PASS, APP_TOKEN, B_SHEET_ID, DAMAGE_SHEET_ID, DAMAGE_DRIVE_FOLDER_ID
// ==========================================

const USER = "YOUR_USERNAME";
const PASS = "YOUR_PASSWORD";
const MAIN_SHEET_ID = "YOUR_MAIN_SHEET_ID";
const DEFAULT_DAMAGE_SHEET_ID = "17nQDnJogZapc8W5RHU8HN8hoSHg_ctym8H37tQWpw68";

const SPREADSHEET_MAP = {
  "P": { id: "YOUR_P_SHEET_ID", column: "E" },
  "E": { id: "YOUR_E_SHEET_ID", column: "E" },
  "I": { id: "YOUR_I_SHEET_ID", column: "E" },
  "C": { id: "YOUR_C_SHEET_ID", column: "E" },
  "B": { id: "YOUR_B_SHEET_ID", column: "E" }
};

// Damage tab: A=Date B=Code C=Name D=ImageURL E=DamagedBy F=Count G=Remark
const DAMAGE_TAB_NAME = "Damage";

function getConfig_() {
  const props = PropertiesService.getScriptProperties();
  const bSheetId = props.getProperty("B_SHEET_ID");
  if (bSheetId) SPREADSHEET_MAP["B"].id = bSheetId;
  return {
    user: props.getProperty("APP_USER") || USER,
    pass: props.getProperty("APP_PASS") || PASS,
    token: props.getProperty("APP_TOKEN") || "abouamjad_secure_session_token",
    damageSheetId: props.getProperty("DAMAGE_SHEET_ID") || DEFAULT_DAMAGE_SHEET_ID,
    damageDriveFolderId: props.getProperty("DAMAGE_DRIVE_FOLDER_ID") || ""
  };
}

function isAuthorized_(token) {
  return token && token === getConfig_().token;
}

function extractDate_(cellValue) {
  if (!cellValue) return "";
  const s = cellValue.toString().trim();
  const match = s.match(/\{([^}]+)\}/);
  return match ? match[0].trim() : s;
}

function formatDamageDate_(d) {
  const date = d || new Date();
  return Utilities.formatDate(date, Session.getScriptTimeZone(), "dd/MM/yyyy");
}

function internalGetDescription(scanData) {
  if (!scanData) return "NO CODE";
  const firstChar = scanData.charAt(0).toUpperCase();
  const sheetInfo = SPREADSHEET_MAP[firstChar];
  if (!sheetInfo) return "UNKNOWN CODE TYPE";
  try {
    const sheet = SpreadsheetApp.openById(sheetInfo.id).getActiveSheet();
    const lastRow = sheet.getLastRow();
    if (lastRow === 0) return "EMPTY SHEET";
    const values = sheet.getRange(1, 1, lastRow, sheet.getLastColumn()).getDisplayValues();
    const rowIndex = values.findIndex(row => row[0].toUpperCase() === scanData.toUpperCase());
    if (rowIndex !== -1) {
      const descColumn = sheetInfo.column.charCodeAt(0) - 65;
      return values[rowIndex][descColumn] || "NO DESCRIPTION WRITTEN";
    }
    return "DESCRIPTION NOT FOUND";
  } catch (e) {
    return "ERROR FETCHING";
  }
}

function getOrCreateDamageSheet_(ss) {
  let sheet = ss.getSheetByName(DAMAGE_TAB_NAME);
  if (!sheet) {
    sheet = ss.insertSheet(DAMAGE_TAB_NAME);
    sheet.getRange(1, 1, 1, 7).setValues([["Date", "Code", "Name", "ImageURL", "DamagedBy", "Count", "Remark"]]);
    sheet.getRange(1, 1, 1, 7).setFontWeight("bold");
  }
  return sheet;
}

function uploadDamageImage_(base64Data, toolCode) {
  if (!base64Data) return "";
  const cfg = getConfig_();
  const match = String(base64Data).match(/^data:(image\/\w+);base64,(.+)$/);
  const contentType = match ? match[1] : "image/jpeg";
  const raw = match ? match[2] : String(base64Data).replace(/^data:image\/\w+;base64,/, "");
  const bytes = Utilities.base64Decode(raw);
  const ext = contentType.indexOf("png") >= 0 ? "png" : "jpg";
  const safeCode = (toolCode || "item").replace(/[^\w-]/g, "_");
  const filename = "damage_" + safeCode + "_" + new Date().getTime() + "." + ext;
  const blob = Utilities.newBlob(bytes, contentType, filename);

  let folder;
  if (cfg.damageDriveFolderId) {
    folder = DriveApp.getFolderById(cfg.damageDriveFolderId);
  } else {
    folder = DriveApp.getRootFolder();
  }

  const file = folder.createFile(blob);
  file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
  return "https://drive.google.com/uc?export=view&id=" + file.getId();
}

function internalSubmitDamage_(params) {
  const cfg = getConfig_();
  const toolCode = (params.toolCode || params.code || "").toString().trim().toUpperCase();
  const personCode = (params.personCode || params.damagedBy || "").toString().trim().toUpperCase();
  const count = Math.max(1, Number(params.qty || params.count || 1) || 1);
  const remark = (params.remark || params.remarks || "").toString().trim() || "No remark";
  const rowDate = (params.date || "").toString().trim() || formatDamageDate_(new Date());
  const imageBase64 = params.imageBase64 || params.image || "";

  if (!toolCode) return { error: "Tool code is required" };
  if (!/^[IEBC]/.test(toolCode)) return { error: "Tool code must start with I, E, C, or B" };
  if (!personCode) return { error: "Person code is required" };
  if (!/^P/.test(personCode)) return { error: "Person code must start with P" };

  const toolName = internalGetDescription(toolCode);
  let imageUrl = "";
  if (imageBase64) {
    try {
      imageUrl = uploadDamageImage_(imageBase64, toolCode);
    } catch (err) {
      return { error: "Image upload failed: " + err.message };
    }
  }

  try {
    const ss = SpreadsheetApp.openById(cfg.damageSheetId);
    const sheet = getOrCreateDamageSheet_(ss);
    const nextRow = Math.max(sheet.getLastRow(), 1) + 1;
    sheet.getRange(nextRow, 1, nextRow, 7).setValues([[
      rowDate,
      toolCode,
      toolName,
      imageUrl,
      personCode,
      count,
      remark
    ]]);
    return {
      success: true,
      row: nextRow,
      item: {
        date: rowDate,
        code: toolCode,
        name: toolName,
        image: imageUrl,
        damagedBy: personCode,
        count: count,
        remark: remark
      }
    };
  } catch (err) {
    return { error: err.message };
  }
}

function internalGetDamage_(targetDate) {
  const cfg = getConfig_();
  try {
    const ss = SpreadsheetApp.openById(cfg.damageSheetId);
    const sheet = ss.getSheetByName(DAMAGE_TAB_NAME);
    if (!sheet) return [];

    const lastRow = sheet.getLastRow();
    if (lastRow < 2) return [];

    const rows = sheet.getRange(2, 1, lastRow, 7).getDisplayValues();
    const items = [];

    rows.forEach(row => {
      const rowDate = extractDate_(row[0]);
      if (targetDate && rowDate !== targetDate) return;

      const code = (row[1] || "").toString().trim();
      const name = (row[2] || "").toString().trim();
      const image = (row[3] || "").toString().trim();
      const damagedBy = (row[4] || "").toString().trim() || "Unknown";
      const count = Number(row[5]) || 1;
      const remark = (row[6] || "").toString().trim() || "No remark";

      if (!code && !name && !damagedBy) return;

      items.push({
        code: code,
        name: name || internalGetDescription(code) || code || "Unnamed product",
        image: image,
        damagedBy: damagedBy,
        count: count,
        remark: remark,
        date: rowDate
      });
    });

    return items;
  } catch (err) {
    return { error: err.message };
  }
}

function handleRequest_(params) {
  const action = params.action;
  const cfg = getConfig_();

  if (action === "options") return json({ ok: true });

  if (action === "login") {
    if (params.user === cfg.user && params.pass === cfg.pass) {
      return json({ success: true, token: cfg.token });
    }
    return json({ success: false });
  }

  if (action === "getDesc") {
    if (!isAuthorized_(params.token)) return json({ error: "UNAUTHORIZED" });
    const code = (params.code || "").toUpperCase().trim();
    if (!code) return json({ description: "NO CODE" });
    return json({ description: internalGetDescription(code) });
  }

  const scanData = params.scanData;
  if (scanData) {
    if (!isAuthorized_(params.token)) return json({ error: "UNAUTHORIZED" });
    const lock = LockService.getScriptLock();
    try {
      lock.waitLock(5000);
      const sheet = SpreadsheetApp.openById(MAIN_SHEET_ID).getActiveSheet();
      const colBValues = sheet.getRange("B1:B").getValues();
      let nextRow = 2;
      for (let i = 1; i < colBValues.length; i++) {
        if (!colBValues[i][0] || colBValues[i][0].toString().trim() === "") {
          nextRow = i + 1;
          break;
        }
      }
      sheet.getRange(nextRow, 2).setValue(scanData.toUpperCase());
      return json({ status: "OK" });
    } catch (error) {
      return json({ error: "SERVER_BUSY" });
    } finally {
      lock.releaseLock();
    }
  }

  if (action && !isAuthorized_(params.token)) {
    return json({ error: "UNAUTHORIZED" });
  }

  if (action === "getDates") {
    try {
      const sheet = SpreadsheetApp.openById(MAIN_SHEET_ID).getActiveSheet();
      const lastRow = sheet.getLastRow();
      if (lastRow < 2) return json([]);

      const rows = sheet.getRange(2, 8, lastRow, 1).getDisplayValues();
      const datesList = [];
      rows.forEach(row => {
        const cellValue = row[0].trim();
        if (!cellValue) return;
        datesList.push(extractDate_(cellValue));
      });
      return json([...new Set(datesList)].filter(String));
    } catch (err) {
      return json({ error: err.message });
    }
  }

  if (action === "getData") {
    const targetDate = params.date;
    try {
      const sheet = SpreadsheetApp.openById(MAIN_SHEET_ID).getActiveSheet();
      const lastRow = sheet.getLastRow();
      if (lastRow < 2) return json([]);

      const rows = sheet.getRange(2, 1, lastRow, 8).getDisplayValues();
      const historyData = [];

      for (let i = 0; i < rows.length; i++) {
        const qrCode = rows[i][1];
        const timestamp = (rows[i][7] || "").toString().trim();
        if (!qrCode) continue;
        historyData.push({
          toolCode: qrCode,
          rowDate: extractDate_(timestamp),
          timestamp: timestamp
        });
      }

      const uniqueCodes = [...new Set(historyData.map(d => d.toolCode))];
      const descMap = {};
      uniqueCodes.forEach(c => { descMap[c] = internalGetDescription(c); });

      return json(historyData.map(d => ({
        toolCode: d.toolCode,
        toolDescription: descMap[d.toolCode],
        rowDate: d.rowDate,
        isTargetDay: (d.rowDate === targetDate)
      })));
    } catch (err) {
      return json({ error: err.message });
    }
  }

  if (action === "getDamage") {
    const targetDate = params.date || "";
    const result = internalGetDamage_(targetDate);
    if (result && result.error) return json(result);
    return json({ items: result });
  }

  if (action === "submitDamage") {
    const result = internalSubmitDamage_(params);
    if (result && result.error) return json(result);
    return json(result);
  }

  return json({ error: "NO ACTION SPECIFIED" });
}

function doGet(e) {
  return handleRequest_((e && e.parameter) || {});
}

function doPost(e) {
  let params = (e && e.parameter) || {};
  if (e && e.postData && e.postData.contents) {
    const type = (e.postData.type || "").toLowerCase();
    // text/plain POST avoids browser CORS preflight on GitHub Pages
    if (type.indexOf("application/json") >= 0 || type.indexOf("text/plain") >= 0) {
      try {
        params = JSON.parse(e.postData.contents);
      } catch (err) {
        return json({ error: "INVALID_JSON" });
      }
    }
  }
  return handleRequest_(params);
}

function json(o) {
  return ContentService.createTextOutput(JSON.stringify(o)).setMimeType(ContentService.MimeType.JSON);
}
